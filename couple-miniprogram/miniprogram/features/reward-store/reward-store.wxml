<view class="page reward-store-page">
  <view class="hero almanac-hero"><view class="almanac-code">EXCHANGE / LEDGER</view><view class="title">奖励商城</view><view class="subtitle">把想为彼此兑现的小事，变成有确认、有结果的约定。</view></view>
  <view class="segment-control"><button class="{{mode === 'store' ? 'is-active' : ''}}" data-mode="store" bindtap="switchMode">商城</button><button class="{{mode === 'inventory' ? 'is-active' : ''}}" data-mode="inventory" bindtap="switchMode">仓库</button></view>

  <block wx:if="{{mode === 'store'}}">
    <view class="panel"><view class="panel-kicker">NEW REWARD</view><view class="field"><view class="label">奖励名称</view><input value="{{form.title}}" data-key="title" bindinput="onInput" placeholder="例如：周末早餐券" /></view><view class="field"><view class="label">说明</view><textarea value="{{form.detail}}" data-key="detail" bindinput="onInput" placeholder="怎么兑现，由谁完成" /></view><view class="field"><view class="label">需要积分</view><input type="number" value="{{form.points}}" data-key="points" bindinput="onInput" /></view><button class="button" loading="{{submitting}}" bindtap="createItem">上架奖励</button></view>
    <view class="section-heading"><text>可兑换</text><text class="almanac-code">{{items.length}} ITEMS</text></view>
    <state-view wx:if="{{!items.length && !loading}}" title="还没有奖励商品" description="先上架一个愿意为彼此兑现的小约定。" />
    <archive-card wx:for="{{items}}" wx:key="_id"><view class="reward-item"><view><view class="record-title">{{item.title}}</view><view class="record-content">{{item.detail || '由两个人共同约定兑现方式'}}</view><button wx:if="{{item.createdBy === openid}}" class="text-action" data-id="{{item._id}}" bindtap="requestArchive">下架</button></view><view class="reward-item__action"><text>{{item.points}} 分</text><button class="button compact" data-id="{{item._id}}" bindtap="redeem">兑换</button></view></view></archive-card>
  </block>

  <block wx:else>
    <state-view wx:if="{{!inventory.length && !loading}}" title="仓库还是空的" description="兑换后的奖励会等待伴侣确认，再由兑换人标记使用。" />
    <archive-card wx:for="{{inventory}}" wx:key="_id"><view class="inventory-item"><view class="archive-stamp">{{item.status === 'pending' ? '待兑现' : item.status === 'ready' ? '可使用' : '已使用'}}</view><view class="record-title">{{item.title}}</view><view class="record-meta">{{item.points}} 积分 · {{item.ownerOpenid === openid ? '我的奖励' : '伴侣的奖励'}}</view><button wx:if="{{item.status === 'pending' && item.ownerOpenid !== openid}}" class="button secondary compact" data-id="{{item._id}}" data-status="ready" bindtap="advance">确认兑现</button><button wx:if="{{item.status === 'ready' && item.ownerOpenid === openid}}" class="button compact" data-id="{{item._id}}" data-status="used" bindtap="advance">标记已使用</button></view></archive-card>
  </block>
  <view wx:if="{{error}}" class="error-banner">{{error}}</view>
  <confirm-dialog open="{{!!archiveItemId}}" title="下架这个奖励？" detail="下架后不会影响已经兑换到仓库的奖励。" confirm-text="确认下架" bindcancel="cancelArchive" bindconfirm="confirmArchive" />
</view>
