.agent-page { padding-bottom: calc(350rpx + env(safe-area-inset-bottom)); }
.agent-hero { padding-bottom: 18rpx; }
.trust-card { border-left-color: var(--moss); background: var(--surface-muted); box-shadow: none; }
.provider-card { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-top: 18rpx; padding: 18rpx 20rpx; border: 1rpx solid var(--line); border-left: 5rpx solid var(--cobalt); border-radius: var(--radius-sm); background: var(--surface); }
.provider-card--ok { border-left-color: var(--moss); }
.provider-card--notice { border-left-color: var(--brass); background: var(--surface-muted); }
.provider-card__copy { min-width: 0; flex: 1; }
.provider-card__status { margin-top: 6rpx; color: var(--ink-strong); font-size: 26rpx; font-weight: 700; }
.provider-card__button { min-width: 150rpx; min-height: 72rpx; margin: 0; padding: 0 18rpx; border: 1rpx solid var(--line); background: transparent; color: var(--cobalt); font-size: 22rpx; line-height: 72rpx; }
.starter { margin-top: 36rpx; }
.prompt-frame-list { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-top: 12rpx; }
.prompt-frame { min-height: 112rpx; margin: 0; padding: 18rpx; border: 1rpx solid var(--line); border-left: 5rpx solid var(--coral); border-radius: var(--radius-sm); background: var(--surface); color: var(--ink-strong); line-height: 1.4; text-align: left; }
.prompt-frame view { font-size: 24rpx; font-weight: 700; }
.prompt-frame text { display: block; margin-top: 6rpx; color: var(--ink-soft); font-size: 20rpx; }
.suggestion { display: flex; width: 100%; min-height: 84rpx; align-items: center; justify-content: space-between; margin: 12rpx 0 0; padding: 0 22rpx; border: 1rpx solid var(--line); border-radius: var(--radius-sm); background: var(--surface); color: var(--ink-strong); font-size: 25rpx; line-height: 1.5; text-align: left; }
.suggestion text { color: var(--cobalt); font-size: 34rpx; }
.conversation { margin-top: 28rpx; }
.message { margin-top: 20rpx; padding: 24rpx; border: 1rpx solid var(--line); border-radius: var(--radius-md); background: var(--surface); }
.message--user { margin-left: 54rpx; border-left: 5rpx solid var(--amber); background: #f5eee3; }
.message--assistant { margin-right: 24rpx; border-left: 5rpx solid var(--cobalt); }
.message__head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; margin-bottom: 12rpx; }
.message__label { color: var(--ink-soft); font-size: 21rpx; font-weight: 700; letter-spacing: 1rpx; }
.message__mode { color: var(--cobalt); font-size: 19rpx; }
.message__content { display: block; color: var(--ink-strong); font-size: 27rpx; line-height: 1.78; white-space: pre-wrap; }
.message__copy { min-height: 68rpx; margin: 18rpx 0 0; padding: 0 18rpx; border: 1rpx solid var(--line); background: transparent; color: var(--cobalt); font-size: 22rpx; line-height: 68rpx; }
.sources { margin-top: 22rpx; padding-top: 18rpx; border-top: 1rpx solid var(--line); }
.sources__title { margin-bottom: 12rpx; color: var(--ink-soft); font-size: 21rpx; }
.source { margin-top: 10rpx; padding: 16rpx; border-radius: var(--radius-sm); background: var(--surface-muted); }
.source__code { color: var(--cobalt); font-family: Menlo, Consolas, monospace; font-size: 19rpx; font-weight: 700; }
.source__title { margin-top: 6rpx; color: var(--ink-strong); font-size: 24rpx; font-weight: 650; }
.source__excerpt { margin-top: 6rpx; color: var(--ink-soft); font-size: 22rpx; line-height: 1.6; }
.agent-state { display: flex; align-items: center; gap: 14rpx; margin-top: 20rpx; color: var(--ink-soft); font-size: 23rpx; }
.error-banner { margin-top: 20rpx; padding: 20rpx; border-radius: var(--radius-sm); background: #f5e4e1; color: var(--danger); }
.notice-banner { margin-top: 20rpx; padding: 18rpx 20rpx; border-left: 5rpx solid var(--brass); border-radius: var(--radius-sm); background: var(--surface-muted); color: var(--ink); font-size: 22rpx; line-height: 1.6; }
.composer { position: fixed; right: 0; bottom: 0; left: 0; z-index: 10; padding: 18rpx 28rpx calc(22rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid var(--line); background: rgba(252, 253, 252, .97); box-shadow: 0 -12rpx 30rpx rgba(31,45,49,.08); }
.composer__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10rpx; color: var(--moss); font-size: 21rpx; font-weight: 650; }
.composer__head button { min-height: 56rpx; margin: 0; padding: 0 12rpx; background: transparent; color: var(--ink-soft); font-size: 21rpx; line-height: 56rpx; }
.composer textarea { min-height: 92rpx; max-height: 190rpx; padding: 16rpx 18rpx; font-size: 25rpx; }
.composer .button { min-height: 76rpx; margin-top: 12rpx; line-height: 76rpx; }
.caveat { margin-top: 10rpx; color: var(--ink-soft); font-size: 19rpx; line-height: 1.5; text-align: center; }
@media (max-width: 340px) {
  .prompt-frame-list { grid-template-columns: 1fr; }
  .provider-card { align-items: flex-start; }
}
@media (prefers-color-scheme: dark) {
  .message--user { background: #2b2b25; }
  .composer { background: rgba(27, 42, 47, .97); }
}
