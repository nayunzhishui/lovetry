page {
  --ink-strong: #292b31;
  --ink: #464950;
  --ink-soft: #77786f;
  --paper: #f7f3eb;
  --surface: #fffdf8;
  --surface-muted: #f0ebe2;
  --line: #ded6c9;
  --amber: #b77932;
  --amber-deep: #85501f;
  --sage: #718577;
  --danger: #a8584e;
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  --radius-sm: 12rpx;
  --radius-md: 22rpx;
  --radius-lg: 32rpx;
  --shadow-card: 0 12rpx 36rpx rgba(73, 61, 44, 0.08);

  min-height: 100%;
  background: var(--paper);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

button,
input,
textarea {
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  position: relative;
  padding: 34rpx 4rpx 30rpx;
  overflow: hidden;
}

.eyebrow {
  margin-bottom: 12rpx;
  color: var(--amber-deep);
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
}

.title {
  color: var(--ink-strong);
  font-family: "Songti SC", "STSong", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 1rpx;
  word-break: break-word;
}

.subtitle {
  margin-top: 12rpx;
  color: var(--ink-soft);
  font-size: 25rpx;
  line-height: 1.7;
  word-break: break-word;
}

/* Signature: two independent tracks that meet at a shared moment. */
.dual-rail {
  display: flex;
  align-items: center;
  width: 128rpx;
  height: 24rpx;
  margin-bottom: 20rpx;
}

.dual-rail__line {
  flex: 1;
  height: 2rpx;
  background: var(--amber);
}

.dual-rail__line:last-child {
  background: var(--sage);
}

.dual-rail__meeting {
  width: 14rpx;
  height: 14rpx;
  margin: 0 8rpx;
  border: 3rpx solid var(--surface);
  border-radius: 50%;
  background: var(--amber-deep);
  box-shadow: 0 0 0 2rpx var(--amber-deep);
}

.panel,
.card {
  margin-top: var(--space-3);
  padding: 28rpx;
  border: 1rpx solid rgba(133, 80, 31, 0.09);
  border-radius: var(--radius-md);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.panel--quiet {
  background: var(--surface-muted);
  box-shadow: none;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-2);
}

.panel-title,
.label {
  color: var(--ink-strong);
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.45;
}

.panel-kicker {
  margin-bottom: 8rpx;
  color: var(--amber-deep);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.field {
  margin-top: 28rpx;
}

.field:first-child {
  margin-top: 0;
}

.field-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.field-index {
  color: var(--amber);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.field .label {
  margin-bottom: 12rpx;
}

.field-head .label {
  margin-bottom: 0;
}

input,
textarea,
.input-like {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  background: #fffefa;
  color: var(--ink-strong);
  font-size: 28rpx;
  transition: border-color 160ms ease, box-shadow 160ms ease;
}

input {
  height: 84rpx;
  padding: 0 22rpx;
  line-height: 84rpx;
}

textarea {
  min-height: 164rpx;
  padding: 20rpx 22rpx;
  line-height: 1.65;
}

input:focus,
textarea:focus {
  border-color: var(--amber);
  box-shadow: 0 0 0 5rpx rgba(183, 121, 50, 0.12);
}

.button {
  min-height: 88rpx;
  margin-top: 28rpx;
  padding: 0 28rpx;
  border-radius: 44rpx;
  background: var(--ink-strong);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 650;
  line-height: 88rpx;
  letter-spacing: 1rpx;
  transition: opacity 140ms ease, transform 140ms ease;
}

.button:active {
  opacity: 0.82;
  transform: scale(0.99);
}

.button.secondary {
  border: 1rpx solid var(--line);
  background: var(--surface);
  color: var(--ink-strong);
}

.button.compact {
  min-height: 72rpx;
  margin-top: 0;
  padding: 0 26rpx;
  font-size: 24rpx;
  line-height: 72rpx;
}

.button[disabled] {
  background: #b9b6af;
  color: #f7f5f0;
  opacity: 1;
}

.nav-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.nav-item {
  position: relative;
  min-height: 158rpx;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(133, 80, 31, 0.09);
  border-radius: var(--radius-md);
  background: var(--surface);
  box-shadow: var(--shadow-card);
  transition: transform 140ms ease, box-shadow 140ms ease;
}

.nav-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 18rpx rgba(73, 61, 44, 0.08);
}

.nav-mark {
  display: block;
  width: 32rpx;
  height: 4rpx;
  margin-bottom: 20rpx;
  border-radius: 2rpx;
  background: var(--amber);
}

.nav-item:nth-child(even) .nav-mark {
  background: var(--sage);
}

.nav-title {
  color: var(--ink-strong);
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.nav-desc {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 23rpx;
  line-height: 1.5;
}

.status {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: #e8eee9;
  color: #536a59;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 44rpx;
}

.status--warm {
  background: #f2e6d5;
  color: var(--amber-deep);
}

.empty {
  margin-top: var(--space-3);
  padding: 54rpx 30rpx;
  border: 1rpx dashed #cabfae;
  border-radius: var(--radius-md);
  color: var(--ink-soft);
  text-align: center;
}

.empty-title {
  color: var(--ink-strong);
  font-size: 28rpx;
  font-weight: 650;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.record {
  position: relative;
  margin: 0 0 18rpx 46rpx;
  padding: 26rpx 26rpx 26rpx 30rpx;
  border: 1rpx solid rgba(133, 80, 31, 0.09);
  border-radius: var(--radius-md);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.record-title {
  color: var(--ink-strong);
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.record-meta {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

.record-content {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-word;
}

.hint {
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 23rpx;
  line-height: 1.6;
}

@media (max-width: 340px) {
  .page {
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .nav-grid {
    grid-template-columns: 1fr;
  }

  .title {
    font-size: 42rpx;
  }

  .panel,
  .card {
    padding: 24rpx;
  }
}

@media (prefers-reduced-motion: reduce) {
  input,
  textarea,
  .button,
  .nav-item {
    transition: none;
  }
}
