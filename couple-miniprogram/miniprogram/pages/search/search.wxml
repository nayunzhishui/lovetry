<view class="page">
  <view class="hero"><view class="eyebrow">FIND A MOMENT</view><view class="title">搜索共同记录</view><view class="subtitle">按标题或正文寻找计划和回忆。</view></view>
  <view class="panel">
    <view class="label">搜索词</view>
    <input value="{{keyword}}" maxlength="50" placeholder="例如：旅行、火锅、生日" bindinput="onInput" confirm-type="search" bindconfirm="search" />
    <view class="filter-row">
      <button class="filter-chip {{source === '' ? 'filter-chip--active' : ''}}" data-source="" bindtap="selectSource">全部</button>
      <button class="filter-chip {{source === 'record' ? 'filter-chip--active' : ''}}" data-source="record" bindtap="selectSource">记录</button>
      <button class="filter-chip {{source === 'plan' ? 'filter-chip--active' : ''}}" data-source="plan" bindtap="selectSource">计划</button>
    </view>
    <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="selectType">
      <view class="input-like type-picker"><text>内容类型</text><text>{{selectedTypeLabel}} ›</text></view>
    </picker>
    <view class="date-row">
      <picker mode="date" value="{{startDate}}" data-field="startDate" bindchange="onFilterInput"><view class="input-like">{{startDate || '开始日期'}}</view></picker>
      <picker mode="date" value="{{endDate}}" data-field="endDate" bindchange="onFilterInput"><view class="input-like">{{endDate || '结束日期'}}</view></picker>
    </view>
    <view class="search-actions">
      <button class="button secondary compact" disabled="{{loading}}" bindtap="clearFilters">清除筛选</button>
      <button class="button compact" loading="{{loading}}" disabled="{{loading || !keyword}}" bindtap="search">搜索</button>
    </view>
  </view>
  <view wx:if="{{error}}" class="error-banner">{{error}}</view>
  <view wx:if="{{searched && results.length === 0}}" class="empty"><view class="empty-title">没有找到相关内容</view><view class="empty-desc">换一个更短的关键词，或清除部分筛选条件。</view></view>
  <button wx:for="{{results}}" wx:key="id" class="card result-card" data-id="{{item.id}}" data-source="{{item.source}}" bindtap="openResult">
    <view class="result-card__meta"><text>{{item.sourceLabel}} · {{item.typeLabel}}</text><text>{{item.dateText}}</text></view>
    <view class="panel-title">{{item.title || '未命名内容'}}</view>
    <view class="result-card__arrow">查看详情 ›</view>
  </button>
</view>
