<view class="page">
  <view class="hero"><view class="eyebrow">FIND A MOMENT</view><view class="title">搜索共同记录</view><view class="subtitle">按标题或正文寻找计划和回忆。</view></view>
  <view class="panel">
    <input value="{{keyword}}" placeholder="例如：旅行、火锅、生日" bindinput="onInput" confirm-type="search" bindconfirm="search" />
    <view class="filter-row">
      <button class="filter-chip {{source === '' ? 'filter-chip--active' : ''}}" data-source="" bindtap="selectSource">全部</button>
      <button class="filter-chip {{source === 'record' ? 'filter-chip--active' : ''}}" data-source="record" bindtap="selectSource">记录</button>
      <button class="filter-chip {{source === 'plan' ? 'filter-chip--active' : ''}}" data-source="plan" bindtap="selectSource">计划</button>
    </view>
    <input value="{{type}}" placeholder="类型筛选：如 mood、trip（可不填）" data-field="type" bindinput="onFilterInput" />
    <view class="date-row">
      <picker mode="date" value="{{startDate}}" data-field="startDate" bindchange="onFilterInput"><view class="input-like">{{startDate || '开始日期'}}</view></picker>
      <picker mode="date" value="{{endDate}}" data-field="endDate" bindchange="onFilterInput"><view class="input-like">{{endDate || '结束日期'}}</view></picker>
    </view>
    <button class="button" loading="{{loading}}" disabled="{{loading || !keyword}}" bindtap="search">搜索</button>
  </view>
  <view wx:if="{{error}}" class="error-banner">{{error}}</view>
  <view wx:if="{{searched && results.length === 0}}" class="empty"><view class="empty-title">没有找到相关内容</view><view class="empty-desc">换一个更短的关键词试试。</view></view>
  <view wx:for="{{results}}" wx:key="id" class="card" data-id="{{item.id}}" data-source="{{item.source}}" bindtap="openResult"><view class="panel-kicker">{{item.source}} · {{item.type}}</view><view class="panel-title">{{item.title}}</view></view>
</view>
