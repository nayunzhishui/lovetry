.reflection-note {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 4rpx;
  padding: 24rpx 26rpx;
}

.reflection-mark {
  flex: none;
  color: var(--amber);
  font-family: Georgia, serif;
  font-size: 48rpx;
  line-height: 0.9;
}

.reflection-copy {
  color: var(--ink);
  font-size: 24rpx;
  line-height: 1.7;
}

.conflict-form {
  margin-top: 24rpx;
}

.conflict-form textarea {
  min-height: 146rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.score-input {
  flex: none;
  width: 150rpx;
  text-align: center;
}

.score-caption {
  min-width: 0;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.5;
}

@media (max-width: 340px) {
  .score-row {
    align-items: flex-start;
    flex-direction: column;
  }

  .score-input {
    width: 100%;
    text-align: left;
  }
}
