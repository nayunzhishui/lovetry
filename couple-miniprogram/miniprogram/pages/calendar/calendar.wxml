<view class="page">
  <view class="hero">
    <twin-rail />
    <view class="eyebrow">OUR CALENDAR</view>
    <view class="title">共同日历</view>
    <view class="subtitle">共享安排会汇合在这里，私密记录只留在自己的轨道。</view>
  </view>

  <view class="calendar-head">
    <button class="month-button" bindtap="previousMonth">‹</button>
    <view class="calendar-head__center"><view class="panel-title">{{monthLabel}}</view><button class="today-button" bindtap="goToday">回到今天</button></view>
    <button class="month-button" bindtap="nextMonth">›</button>
  </view>
  <scroll-view scroll-x class="calendar-filters" show-scrollbar="{{false}}"><view class="calendar-filters__inner">
    <button wx:for="{{filters}}" wx:key="value" class="filter-chip {{activeFilter === item.value ? 'filter-chip--active' : ''}}" data-filter="{{item.value}}" bindtap="selectFilter">{{item.label}}</button>
  </view></scroll-view>

  <view class="week-row"><view wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="week-cell">{{item}}</view></view>
  <view class="calendar-grid">
    <button wx:for="{{days}}" wx:key="key" class="day {{item.blank ? 'day--blank' : ''}} {{item.isToday ? 'day--today' : ''}} {{selectedKey === item.key ? 'day--selected' : ''}}" disabled="{{item.blank}}" data-key="{{item.key}}" bindtap="selectDay">
      <text wx:if="{{!item.blank}}">{{item.day}}</text>
      <view wx:if="{{item.eventCount}}" class="event-dot"></view>
    </button>
  </view>

  <view wx:if="{{loading}}" class="empty" aria-live="polite"><view class="empty-desc">正在整理这个月的记录…</view></view>
  <view wx:elif="{{error}}" class="error-banner" aria-live="polite"><view>{{error}}</view><button class="button secondary compact" bindtap="retryMonth">重新加载</button></view>
  <view wx:else class="panel calendar-agenda">
    <view class="calendar-agenda__head">
      <view><view class="panel-kicker">SELECTED DAY</view><view class="calendar-agenda__date">{{selectedKey}}</view></view>
      <view class="calendar-agenda__count">{{selectedEvents.length}} 项</view>
    </view>
    <view class="calendar-quick-actions"><button class="button secondary compact" bindtap="addRecordForSelectedDay">记下这一天</button><button class="button secondary compact" bindtap="addPlanForSelectedDay">安排这一天</button></view>
    <view wx:if="{{selectedEvents.length === 0}}" class="calendar-agenda__empty"><view class="empty-title">这一天还是空白</view><view class="empty-desc">从上面的入口留下回忆或安排。</view></view>
    <block wx:else>
      <button wx:for="{{selectedEvents}}" wx:key="id" class="event-row" data-id="{{item.id}}" bindtap="openEvent">
        <view class="event-time">{{item.timeText || '全天'}}</view>
        <view class="event-main"><view class="event-title">{{item.title}}</view><view class="event-meta">{{item.typeLabel}} · {{item.sourceLabel}}<text wx:if="{{item.statusLabel}}"> · {{item.statusLabel}}</text></view></view>
        <view class="event-arrow" aria-hidden="true">›</view>
      </button>
    </block>
  </view>
</view>
