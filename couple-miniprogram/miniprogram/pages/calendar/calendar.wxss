.calendar-head,
.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.calendar-head {
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  margin: 14rpx 0 22rpx;
  text-align: center;
}
.calendar-head__center { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.today-button { min-height: 48rpx; margin: 0; padding: 0 14rpx; background: transparent; color: var(--cobalt); font-size: 19rpx; line-height: 48rpx; }
.calendar-filters { margin: -4rpx 0 18rpx; white-space: nowrap; }
.calendar-filters__inner { display: inline-flex; gap: 10rpx; }
.filter-chip { min-height: 72rpx; margin: 0; padding: 0 24rpx; border: 1rpx solid var(--line); border-radius: 36rpx; background: var(--surface); color: var(--ink-soft); font-size: 24rpx; line-height: 72rpx; }
.filter-chip--active { border-color: var(--ink-strong); background: var(--ink-strong); color: #fff; }

.month-button {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 50%;
  background: var(--surface);
  color: var(--ink-strong);
  font-size: 42rpx;
  line-height: 64rpx;
}

.week-cell {
  padding: 12rpx 0;
  color: var(--ink-soft);
  font-size: 22rpx;
  text-align: center;
}

.calendar-grid {
  gap: 8rpx;
}

.day {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  aspect-ratio: 1;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  background: var(--surface);
  color: var(--ink);
}

.day--blank {
  background: transparent;
  opacity: 1;
}

.day--selected {
  background: var(--ink-strong);
  color: #fff;
}
.day--today { box-shadow: inset 0 0 0 2rpx var(--cobalt); }
.day--today.day--selected { box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, .7); }

.event-dot {
  position: absolute;
  bottom: 8rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: var(--amber);
}

.event-row {
  display: flex;
  width: 100%;
  align-items: center;
  gap: 16rpx;
  margin: 0;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line);
  border-radius: 0;
  background: transparent;
  text-align: left;
  line-height: 1.5;
}

.event-row:last-child {
  border-bottom: 0;
}

.event-title {
  color: var(--ink-strong);
  font-weight: 700;
  line-height: 1.5;
}

.calendar-agenda { margin-top: 24rpx; }
.calendar-agenda__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 18rpx; }
.calendar-agenda__date { margin-top: 6rpx; color: var(--ink-strong); font-family: "Songti SC", "STSong", serif; font-size: 34rpx; font-weight: 700; }
.calendar-agenda__count { color: var(--ink-soft); font-family: "SFMono-Regular", Consolas, monospace; font-size: 21rpx; }
.calendar-quick-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin: 22rpx 0 10rpx; }
.calendar-quick-actions .button { width: 100%; margin: 0; }
.calendar-agenda__empty { padding: 38rpx 10rpx 20rpx; text-align: center; }
.event-time { flex: 0 0 82rpx; color: var(--cobalt); font-family: "SFMono-Regular", Consolas, monospace; font-size: 21rpx; }
.event-main { min-width: 0; flex: 1; }
.event-meta { margin-top: 4rpx; color: var(--ink-soft); font-size: 19rpx; }
.event-arrow { color: var(--ink-soft); font-size: 34rpx; }

.error-banner {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: var(--radius-sm);
  background: #f5e4e1;
  color: var(--danger);
}
.error-banner .button { width: 220rpx; margin: 18rpx 0 0; }

@media (max-width: 340px) {
  .calendar-grid { gap: 5rpx; }
  .day { border-radius: 14rpx; }
  .calendar-quick-actions { grid-template-columns: 1fr; }
}
