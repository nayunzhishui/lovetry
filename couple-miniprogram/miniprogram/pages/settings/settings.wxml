<view class="page">
  <view class="hero">
    <view class="title">情侣空间</view>
    <view class="subtitle">创建空间后，把加入码发给另一半；对方输入加入码后即可同步记录。</view>
  </view>

  <view wx:if="{{couple}}" class="panel">
    <view class="label">当前加入码</view>
    <view class="title">{{couple.code}}</view>
    <view class="subtitle">成员数：{{couple.members.length}}</view>
  </view>

  <view class="panel">
    <button class="button" bindtap="createCouple">创建情侣空间</button>
    <view class="field">
      <view class="label">加入码</view>
      <input value="{{joinCode}}" placeholder="输入 6 位加入码" bindinput="onJoinCodeInput" />
    </view>
    <button class="button secondary" bindtap="joinCouple">加入情侣空间</button>
  </view>
</view>
