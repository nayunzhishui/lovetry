<view class="page">
  <view class="hero">
    <view class="title">时间线</view>
    <view class="subtitle">查看当前情侣空间内的恋爱经历和吵架复盘。</view>
  </view>

  <button class="button secondary" bindtap="loadRecords">刷新</button>

  <view wx:for="{{records}}" wx:key="_id" class="record">
    <view class="record-title">{{item.typeLabel}}：{{item.title}}</view>
    <view class="record-meta">{{item.createdAtText}}</view>
    <view class="record-content">{{item.content}}</view>
    <view wx:if="{{item.type === 'conflict'}}" class="record-content">
      满意度：{{item.payload.satisfaction}}/10
    </view>
  </view>

  <view wx:if="{{records.length === 0}}" class="panel">
    <view class="subtitle">暂无记录。</view>
  </view>
</view>
