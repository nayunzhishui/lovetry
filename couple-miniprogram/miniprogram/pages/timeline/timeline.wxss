.timeline-hero {
  padding-bottom: 20rpx;
}

.timeline-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin: 8rpx 0 32rpx;
  padding: 0 4rpx;
}

.timeline-count {
  color: var(--ink-strong);
  font-size: 27rpx;
  font-weight: 650;
}

.timeline-list {
  position: relative;
  padding-top: 4rpx;
}

.timeline-tracks {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 15rpx;
  display: flex;
  gap: 9rpx;
  width: 13rpx;
}

.timeline-track {
  width: 2rpx;
  background: rgba(183, 121, 50, 0.5);
}

.timeline-track--sage {
  background: rgba(113, 133, 119, 0.55);
}

.timeline-record:last-child {
  margin-bottom: 0;
}

.timeline-node {
  position: absolute;
  top: 34rpx;
  left: -42rpx;
  z-index: 1;
  width: 15rpx;
  height: 15rpx;
  border: 5rpx solid var(--paper);
  border-radius: 50%;
  background: var(--amber-deep);
  box-shadow: 0 0 0 2rpx var(--amber-deep);
}

.record-type {
  display: inline-block;
  margin-bottom: 10rpx;
  color: var(--amber-deep);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.record-extra {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--line);
}

.record-extra__label {
  color: var(--ink-soft);
  font-size: 22rpx;
}

.record-extra__value {
  color: var(--ink-strong);
  font-family: "SFMono-Regular", Consolas, monospace;
  font-size: 24rpx;
  font-weight: 700;
}

.dual-empty {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  height: 58rpx;
  margin-bottom: 18rpx;
}

.dual-empty view {
  width: 2rpx;
  height: 58rpx;
  background: var(--amber);
}

.dual-empty view:last-child {
  background: var(--sage);
}
.reaction-row { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 22rpx; padding-top: 18rpx; border-top: 1rpx solid var(--line); }
.reaction-chip { min-height: 58rpx; margin: 0; padding: 0 18rpx; border: 1rpx solid var(--line); border-radius: 4rpx; background: transparent; color: var(--ink-soft); font-size: 21rpx; line-height: 58rpx; }
.reaction-chip.is-active { border-color: var(--cobalt); background: rgba(53, 101, 141, 0.08); color: var(--cobalt); }
