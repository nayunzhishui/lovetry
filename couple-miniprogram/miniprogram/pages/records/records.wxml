<view class="page records-page">
  <view class="hero records-hero">
    <view class="dual-rail" aria-hidden="true">
      <view class="dual-rail__line"></view>
      <view class="dual-rail__meeting"></view>
      <view class="dual-rail__line"></view>
    </view>
    <view class="eyebrow">OUR DAILY NOTES</view>
    <view class="title">生活记录</view>
    <view class="subtitle">共享的留在双轨上，私密的只属于你。</view>
  </view>

  <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-row">
      <button
        wx:for="{{typeOptions}}"
        wx:key="value"
        class="filter-chip {{selectedType === item.value ? 'filter-chip--active' : ''}}"
        data-type="{{item.value}}"
        bindtap="selectType"
      >{{item.label}}</button>
    </view>
  </scroll-view>

  <view class="action-row">
    <button class="button compact" data-type="{{selectedType}}" bindtap="createRecord">新增记录</button>
    <button class="button secondary compact" data-type="pomodoro" bindtap="createRecord">开始专注</button>
  </view>
  <view wx:if="{{selectedType === 'outing'}}" class="outing-filters">
    <scroll-view scroll-x show-scrollbar="{{false}}"><view class="filter-row">
      <button wx:for="{{outingCategories}}" wx:key="*this" class="filter-chip {{outingCategory === item ? 'filter-chip--active' : ''}}" data-category="{{item}}" bindtap="selectOutingCategory">{{item || '全部分类'}}</button>
    </view></scroll-view>
    <view class="date-filter"><picker mode="date" value="{{filterDate}}" bindchange="selectFilterDate"><view class="input-like">{{filterDate || '按日期筛选'}}</view></picker><text wx:if="{{filterDate}}" bindtap="clearFilterDate">清除</text></view>
  </view>

  <view wx:if="{{stats}}" class="stats-strip">
    <view class="stats-item"><text>{{stats.last7DaysMinutes}}</text><view>近 7 天{{stats.modeLabel}} / 分钟</view></view>
    <view class="stats-divider"></view>
    <view class="stats-item"><text>{{stats.last30DaysMinutes}}</text><view>近 30 天{{stats.modeLabel}} / 分钟</view></view>
    <view class="stats-divider"></view>
    <view class="stats-item"><text>{{stats.last30DaysCount}}</text><view>近 30 天 / 次</view></view>
  </view>
  <view wx:if="{{stats.trendText}}" class="stats-trend">{{stats.trendText}}</view>

  <view wx:if="{{isLoading}}" class="state-card" aria-live="polite">
    <view class="state-pulse"></view>
    <view>正在整理记录…</view>
  </view>

  <view wx:elif="{{error}}" class="empty" aria-live="polite">
    <view class="empty-title">记录暂时没有加载出来</view>
    <view class="empty-desc">{{error}}</view>
    <button class="button secondary compact state-action" bindtap="loadRecords">重新加载</button>
  </view>

  <view wx:elif="{{records.length === 0}}" class="empty">
    <view class="empty-rails" aria-hidden="true"><view></view><view></view></view>
    <view class="empty-title">这里还没有记录</view>
    <view class="empty-desc">写下今天最想记住的一件小事。</view>
    <button class="button compact state-action" bindtap="createRecord">写第一条</button>
  </view>

  <view wx:else class="record-list">
    <view
      wx:for="{{records}}"
      wx:key="_id"
      class="record record-card"
      hover-class="record-card--pressed"
      data-id="{{item._id}}"
      bindtap="openRecord"
    >
      <view class="record-card__head">
        <view class="record-type">{{item.typeLabel}}</view>
        <view class="record-visibility">{{item.visibilityLabel}}</view>
      </view>
      <view class="record-title">{{item.title || item.typeLabel}}</view>
      <view class="record-meta">{{item.timeText}}<text wx:if="{{item.durationText}}"> · {{item.durationText}}</text></view>
      <view wx:if="{{item.categoryText}}" class="record-category">{{item.categoryText}}</view>
      <view wx:if="{{item.contentPreview}}" class="record-content">{{item.contentPreview}}</view>
      <view class="record-arrow" aria-hidden="true">›</view>
    </view>
  </view>
</view>
