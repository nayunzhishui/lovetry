.home-hero {
  padding-bottom: 24rpx;
}

.sync-ribbon {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 6rpx 0 18rpx;
  color: var(--ink-soft);
  font-family: ui-monospace, "SFMono-Regular", Consolas, monospace;
  font-size: 21rpx;
  letter-spacing: 1rpx;
}

.sync-ribbon__light {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--moss);
  box-shadow: 0 0 0 6rpx rgba(115, 142, 120, 0.12);
}

.empty--home {
  padding-top: 46rpx;
  padding-bottom: 34rpx;
  background: rgba(255, 253, 248, 0.62);
}

.empty--home .button {
  margin-top: 30rpx;
}

.space-card {
  position: relative;
  overflow: hidden;
}

.space-card::after {
  position: absolute;
  right: -28rpx;
  bottom: -44rpx;
  width: 130rpx;
  height: 92rpx;
  border: 2rpx solid rgba(113, 133, 119, 0.18);
  border-radius: 50%;
  content: "";
}

.space-code {
  margin-top: 24rpx;
  color: var(--ink-strong);
  font-family: "SFMono-Regular", Consolas, monospace;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  line-height: 1.25;
  word-break: break-all;
}

.section-head {
  display: flex;
  justify-content: space-between;
  margin-top: 48rpx;
  padding: 0 4rpx;
}

.section-title {
  color: var(--ink-strong);
  font-family: "Songti SC", "STSong", serif;
  font-size: 34rpx;
  font-weight: 700;
}

.moment-panel {
  margin-top: 46rpx;
}

.today-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.today-metric {
  padding: 24rpx 12rpx;
  border: 1rpx solid rgba(133, 80, 31, 0.09);
  border-radius: var(--radius-sm);
  background: var(--surface);
  text-align: center;
}

.today-metric__value {
  color: var(--ink-strong);
  font-family: ui-monospace, "SFMono-Regular", Consolas, monospace;
  font-size: 32rpx;
  font-weight: 700;
}

.today-metric__label {
  margin-top: 7rpx;
  color: var(--ink-soft);
  font-size: 20rpx;
}

.home-links {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  padding: 30rpx 0 8rpx;
}

.home-links button {
  min-height: 72rpx;
  margin: 0;
  padding: 0 18rpx;
  background: transparent;
  color: var(--amber-deep);
  font-size: 23rpx;
  line-height: 72rpx;
}

.moment-panel textarea {
  min-height: 190rpx;
}
.nav-item--agent { grid-column: 1 / -1; min-height: 142rpx; border-top-color: var(--moss); }
.nav-item--agent .nav-mark { background: var(--moss); }
.relationship-note { display: grid; grid-template-columns: .8fr 1.2fr; gap: 1rpx; margin-top: 14rpx; overflow: hidden; border: 1rpx solid var(--line); border-radius: var(--radius-md); background: var(--line); }
.relationship-note > view { padding: 20rpx; background: var(--surface); }
.relationship-note text { display: block; color: var(--ink-strong); font-family: "Songti SC", "STSong", serif; font-size: 28rpx; font-weight: 700; }
.relationship-note view view { margin-top: 6rpx; color: var(--ink-soft); font-size: 19rpx; }
.week-summary { margin-top: 10rpx; color: var(--ink-soft); font-size: 20rpx; text-align: right; }
.anniversary-card { display: flex; width: 100%; align-items: center; justify-content: space-between; gap: 24rpx; margin-right: 0; margin-left: 0; text-align: left; line-height: 1.5; }
.anniversary-card__count { min-width: 120rpx; color: var(--coral); text-align: right; }
.anniversary-card__count text { font-family: "Songti SC", STSong, serif; font-size: 58rpx; line-height: 1; }
.anniversary-card__count view { margin-top: 6rpx; color: var(--ink-soft); font-size: 21rpx; }
