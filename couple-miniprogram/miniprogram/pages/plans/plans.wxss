.plans-hero {
  padding-bottom: 18rpx;
}

.type-tabs {
  width: calc(100% + 56rpx);
  margin-left: -28rpx;
  white-space: nowrap;
}

.type-tabs__inner {
  display: inline-flex;
  gap: 12rpx;
  padding: 10rpx 28rpx 18rpx;
}

.type-tab {
  min-width: 116rpx;
  height: 66rpx;
  margin: 0;
  padding: 0 26rpx;
  border: 1rpx solid var(--line);
  border-radius: 34rpx;
  background: transparent;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 64rpx;
}

.type-tab--active {
  border-color: var(--ink-strong);
  background: var(--ink-strong);
  color: #fff;
}

.choice-card {
  position: relative;
  margin-top: 16rpx;
  padding: 34rpx;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--amber-deep);
  color: #fffaf2;
}

.choice-card::after {
  position: absolute;
  top: -50rpx;
  right: -40rpx;
  width: 190rpx;
  height: 190rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  content: "";
}

.choice-card__label {
  position: relative;
  z-index: 1;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.choice-card__answer {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.choice-card__answer--quiet {
  color: rgba(255, 250, 242, 0.72);
  font-size: 34rpx;
}

.choice-card__meta {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  color: rgba(255, 250, 242, 0.72);
  font-size: 23rpx;
}

.choice-card__button {
  position: relative;
  z-index: 1;
  width: 230rpx;
  margin: 28rpx 0 0;
  background: #fffaf2;
  color: var(--amber-deep);
}

.create-panel {
  margin-top: 20rpx;
}
.composer-launch { display: flex; width: 100%; align-items: center; justify-content: space-between; gap: 20rpx; min-height: 126rpx; margin: 20rpx 0 0; padding: 24rpx 26rpx; border: 1rpx solid var(--line); border-left: 6rpx solid var(--cobalt); background: var(--surface); color: var(--ink-strong); text-align: left; line-height: 1.4; }
.composer-launch__eyebrow { color: var(--cobalt); font-family: "SFMono-Regular", Consolas, monospace; font-size: 18rpx; font-weight: 700; letter-spacing: 2rpx; }
.composer-launch__title { margin-top: 5rpx; font-family: "Songti SC", "STSong", serif; font-size: 29rpx; font-weight: 700; }
.composer-launch__desc { margin-top: 5rpx; color: var(--ink-soft); font-size: 19rpx; }
.composer-launch__mark { display: flex; align-items: center; justify-content: center; flex: 0 0 58rpx; width: 58rpx; height: 58rpx; border-radius: 50%; background: var(--ink-strong); color: #fff; font-size: 34rpx; font-weight: 400; }
.composer-head-actions { display: flex; align-items: center; gap: 8rpx; }
.composer-close { min-height: 58rpx; margin: 0; padding: 0 14rpx; background: transparent; color: var(--cobalt); font-size: 20rpx; line-height: 58rpx; }
.draft-ribbon { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin: 10rpx 0 24rpx; padding: 18rpx 20rpx; border-left: 5rpx solid var(--sage); background: var(--surface-muted); }
.draft-ribbon--restored { border-left-color: var(--cobalt); }
.draft-ribbon__title { color: var(--ink-strong); font-size: 23rpx; font-weight: 700; }
.draft-ribbon__desc { margin-top: 4rpx; color: var(--ink-soft); font-size: 19rpx; line-height: 1.45; }
.draft-ribbon button { flex: 0 0 auto; min-height: 58rpx; margin: 0; padding: 0 14rpx; background: transparent; color: var(--cobalt); font-size: 20rpx; line-height: 58rpx; }
.template-section { margin: 4rpx 0 26rpx; }
.template-list { display: grid; gap: 10rpx; margin-top: 12rpx; }
.template-card { min-height: 84rpx; margin: 0; padding: 14rpx 18rpx; border: 1rpx dashed var(--line); background: var(--surface-muted); color: var(--ink-strong); line-height: 1.35; text-align: left; }
.template-card view { font-size: 23rpx; font-weight: 700; }
.template-card text { display: block; margin-top: 4rpx; color: var(--ink-soft); font-size: 19rpx; }
.submit-hint { margin-top: 12rpx; color: var(--ink-soft); font-size: 19rpx; text-align: center; }

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.form-grid .field {
  margin-top: 28rpx;
}

.form-grid__wide {
  grid-column: 1 / -1;
}

.picker-value {
  height: 84rpx;
  padding: 0 22rpx;
  line-height: 84rpx;
}

.list-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 48rpx 4rpx 22rpx;
}

.list-head__title {
  color: var(--ink-strong);
  font-family: "Songti SC", "STSong", serif;
  font-size: 34rpx;
  font-weight: 700;
}

.list-head__count {
  color: var(--ink-soft);
  font-family: "SFMono-Regular", Consolas, monospace;
  font-size: 22rpx;
}

.state-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  min-height: 174rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  background: var(--surface);
  color: var(--ink-soft);
  font-size: 24rpx;
  text-align: center;
}

.state-card--error {
  display: block;
}

.state-card--error .button {
  width: 220rpx;
  margin: 24rpx auto 0;
}

.state-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--amber);
  animation: state-pulse 900ms ease-in-out infinite alternate;
}

@keyframes state-pulse {
  from { opacity: 0.35; transform: scale(0.8); }
  to { opacity: 1; transform: scale(1.15); }
}

.plan-card {
  position: relative;
  margin-bottom: 18rpx;
  padding: 26rpx 26rpx 24rpx 42rpx;
  overflow: hidden;
  border: 1rpx solid rgba(133, 80, 31, 0.09);
  border-radius: var(--radius-md);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.plan-card--done {
  background: #f2eee6;
  box-shadow: none;
}

.plan-card--done .record-title,
.plan-card--done .record-content {
  opacity: 0.62;
}

.plan-card__rail {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 18rpx;
  display: flex;
  gap: 5rpx;
}

.plan-card__rail view {
  width: 2rpx;
  background: rgba(183, 121, 50, 0.55);
}

.plan-card__rail view:last-child {
  background: rgba(113, 133, 119, 0.55);
}

.plan-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.plan-card__type {
  color: var(--amber-deep);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.plan-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 18rpx;
  margin-top: 18rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
}

.plan-card__action {
  width: 210rpx;
  margin: 22rpx 0 0 auto;
}
.plan-actions { display: flex; justify-content: flex-end; gap: 10rpx; margin-top: 22rpx; }
.plan-actions .button { width: auto; margin: 0; }
.danger-action { color: var(--danger); }

.checklist {
  display: grid;
  gap: 10rpx;
  margin-top: 18rpx;
}

.checklist__item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 8rpx 12rpx;
  background: transparent;
  color: var(--ink);
  font-size: 22rpx;
  line-height: 1.4;
  text-align: left;
}

.checklist__box {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 30rpx;
  width: 30rpx;
  height: 30rpx;
  border: 1rpx solid var(--sage);
  border-radius: 50%;
  color: var(--sage);
}

.checklist__item--done {
  color: var(--ink-soft);
  text-decoration: line-through;
}

.itinerary { display: grid; gap: 10rpx; margin-top: 18rpx; }
.itinerary__item { display: flex; align-items: center; gap: 12rpx; color: var(--ink-soft); font-size: 22rpx; }
.itinerary__item text { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--amber); }

@media (max-width: 340px) {
  .type-tabs {
    width: calc(100% + 44rpx);
    margin-left: -22rpx;
  }

  .type-tabs__inner {
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .form-grid {
    grid-template-columns: 1fr;
    gap: 0;
  }

  .form-grid__wide {
    grid-column: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  .state-pulse {
    animation: none;
  }
}
